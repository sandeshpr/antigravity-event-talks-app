# pyenv
#   For a library or app, you might want to share your .python-version.
#   Document, but not necessarily ignore, this file.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used, it is sometimes ignored.
#   https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-setup-py
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   Poetry's own lock file is ignored by some users.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm build directory
.pdm-build/

